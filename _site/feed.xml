    <summary>
      





      


import Foundation

func solution(_ n:Int) -&amp;gt; Int {
    
    var answer : Int = 0
    
    answer = n &amp;gt; 7 ? (n%7 == 0) ? n/7 : (n/7)+1 : 1
    
    return answer
}



삼항연산자를 2중으로 하여 해결하려고 하였다.

